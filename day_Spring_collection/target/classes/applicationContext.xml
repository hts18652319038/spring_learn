<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="bookDao" class="com.xzit.dao.impl.BookDaoImpl">
        <property name="array">
            <array>
                <value>100</value>
                <value>200</value>
                <value>300</value>
            </array>
        </property>
        <property name="list">
            <list>
                <value>Java</value>
                <value>Spring</value>
                <value>Mybatis</value>
            </list>
        </property>
        <property name="set">
            <set>
                <value>动物</value>
                <value>植物</value>
                <value>微生物</value>
            </set>
        </property>
        <property name="map">
            <map>
                <entry key="country" value="中国"/>
                <entry key="province" value="上海市"/>
                <entry key="city" value="浦东新区"/>
            </map>
        </property>
        <property name="properties">
            <props>
                <prop key="country">中国</prop>
                <prop key="province">江苏省</prop>
                <prop key="city">淮安市</prop>
            </props>
        </property>
    </bean>
</beans>
